# Project Dualis Backend - Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# LLM Configuration (OpenAI-compatible)
# For DeepSeek: https://api.deepseek.com/v1
# For OpenAI: https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_HTTP_PORT=6334
QDRANT_COLLECTION_PREFIX=dualis

# Memory Configuration
MEMORY_WORKING_TTL=3600
MEMORY_MAX_RETRIEVAL=20
MEMORY_CHAIN_DEPTH=3

# Sandbox Configuration (Phase 2.5)
SANDBOX_ENABLED=false
SANDBOX_DOCKER_IMAGE=python:3.10-slim
SANDBOX_TIMEOUT=30

# Application Mode
DEFAULT_MODE=companion
